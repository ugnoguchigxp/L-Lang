{
  "version": 1,
  "tests": [
    { "name": "eligible", "input": { "status": "active", "deletedAt": null, "email": "a@example.com" }, "expected": true },
    { "name": "suspended", "input": { "status": "suspended", "deletedAt": null, "email": "a@example.com" }, "expected": false },
    { "name": "deleted", "input": { "status": "active", "deletedAt": "2026-01-01", "email": "a@example.com" }, "expected": false },
    { "name": "no contact", "input": { "status": "active", "deletedAt": null, "email": null }, "expected": false }
  ]
}
