        ]},
        "ambiguity": {"typeName":"V2PayableInvoiceAmbiguity","expectedOutcome":"unresolved","fields":[
          {"path":["approvalStage"],"type":"\"approved\" | \"draft\"","positive":"approved"},
          {"path":["voidedAt"],"type":"string | null","positive":null},
          {"path":["bankReference"],"type":"string | null","positive":"bank-1"},
          {"path":["cardReference"],"type":"string | null","positive":"card-1"}
        ]}
      }
    },
    {
