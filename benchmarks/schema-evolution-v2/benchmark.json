{
  "version": 2,
  "name": "blind-schema-evolution-v2",
  "trials": 3,
  "thresholds": {
    "minimumConsensusCaseRate": 0.95,
    "minimumConsensusQuorumRate": 0.9,
    "maximumFalseResolutionRate": 0,
    "maximumWorkspaceMutationCount": 0
  },
  "concepts": [
    {
      "id": "benchmark.v2.ticket.actionable",
      "exportName": "V2ActionableTicket",
      "displayName": "Actionable Ticket",
      "specification": "A support ticket that can be acted on now. The supplied schema's authoritative workflow indicator is positive, no blocking state or timestamp represented by that schema is active, and an assigned owner is present. Use only semantic roles unambiguously represented by the supplied type. If workflow, blocking, or ownership roles require guessing, leave the concept unresolved.",
      "baseline": {
        "typeName": "V2ActionableTicketBaseline",
        "expectedOutcome": "resolved",
        "fields": [
          {"path":["state"],"type":"\"open\" | \"closed\"","positive":"open","negative":"closed","condition":{"kind":"equals","value":"open"}},
          {"path":["blockedAt"],"type":"string | null","positive":null,"negative":"2026-01-01","condition":{"kind":"equals","value":null}},
          {"path":["assigneeId"],"type":"string | null","positive":"agent-1","negative":null,"condition":{"kind":"present"}}
        ]
      },
      "cases": {
        "add-property": {"typeName":"V2ActionableTicketAddProperty","expectedOutcome":"resolved","fields":[
          {"path":["state"],"type":"\"open\" | \"closed\"","positive":"open","negative":"closed","condition":{"kind":"equals","value":"open"}},
          {"path":["blockedAt"],"type":"string | null","positive":null,"negative":"2026-01-01","condition":{"kind":"equals","value":null}},
          {"path":["assigneeId"],"type":"string | null","positive":"agent-1","negative":null,"condition":{"kind":"present"}},
          {"path":["priority"],"type":"\"low\" | \"high\"","positive":"high"}
        ]},
        "rename": {"typeName":"V2ActionableTicketRename","expectedOutcome":"resolved","fields":[
          {"path":["workflowState"],"type":"\"open\" | \"closed\"","positive":"open","negative":"closed","condition":{"kind":"equals","value":"open"}},
          {"path":["holdPlacedAt"],"type":"string | null","positive":null,"negative":"2026-01-01","condition":{"kind":"equals","value":null}},
          {"path":["ownership","primaryAgentId"],"type":"string | null","positive":"agent-1","negative":null,"condition":{"kind":"present"}}
        ]},
        "representation": {"typeName":"V2ActionableTicketRepresentation","expectedOutcome":"resolved","fields":[
          {"path":["actionable"],"type":"boolean","positive":true,"negative":false,"condition":{"kind":"equals","value":true}},
          {"path":["blocked"],"type":"boolean","positive":false,"negative":true,"condition":{"kind":"equals","value":false}},
          {"path":["assigneeIds"],"type":"string[] | null","positive":["agent-1"],"negative":null,"condition":{"kind":"present"}}
        ]},
        "optionality": {"typeName":"V2ActionableTicketOptionality","expectedOutcome":"resolved","fields":[
          {"path":["state"],"type":"\"open\" | \"closed\"","positive":"open","negative":"closed","condition":{"kind":"equals","value":"open"}},
          {"path":["blockedAt"],"type":"string | null","optional":true,"omitWhenNegative":true,"positive":null,"negative":"2026-01-01","condition":{"kind":"equals","value":null}},
          {"path":["assigneeId"],"type":"string | null","optional":true,"omitWhenNegative":true,"positive":"agent-1","negative":null,"condition":{"kind":"present"}}
        ]},
        "remove-role": {"typeName":"V2ActionableTicketRemoveRole","expectedOutcome":"unresolved","fields":[
          {"path":["state"],"type":"\"open\" | \"closed\"","positive":"open"},
          {"path":["blockedAt"],"type":"string | null","positive":null},
          {"path":["priority"],"type":"number","positive":1}
        ]},
        "ambiguity": {"typeName":"V2ActionableTicketAmbiguity","expectedOutcome":"unresolved","fields":[
          {"path":["state"],"type":"\"open\" | \"closed\"","positive":"open"},
          {"path":["blockedAt"],"type":"string | null","positive":null},
          {"path":["primaryAssigneeId"],"type":"string | null","positive":"agent-1"},
          {"path":["backupAssigneeId"],"type":"string | null","positive":"agent-2"}
        ]}
      }
    },
    {
