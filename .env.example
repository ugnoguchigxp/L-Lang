# Copy this file to .env and set your API key.
OPENAI_API_KEY=sk-your-api-key

# Optional overrides.
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI also uses these same variable names:
# OPENAI_API_KEY=<Azure OpenAI API key>
# OPENAI_MODEL=gpt-5-4-mini # Azure deployment name for GPT-5.4 mini
# OPENAI_BASE_URL=https://<resource-name>.openai.azure.com
